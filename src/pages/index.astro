    .footer-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 5rem 2rem 2rem;
    }

    .footer-content {
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr;
      gap: 5rem;
      padding-bottom: 4rem;
      border-bottom: 1px solid rgba(212, 165, 116, 0.1);
    }

    .footer-section {
    }

    .footer-logo {
      width: 100px;
