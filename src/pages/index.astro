        transform: translateY(0);
        text-align: center;
        padding: 0.5rem 1rem;
        font-size: 0.875rem;
      }

      /* Fix 3: Center portfolio project content on mobile */
      .project-details {
        text-align: center;
        align-items: center;
      }

      .project-header {
