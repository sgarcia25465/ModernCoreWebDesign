      font-weight: 700;
      line-height: 1.2;
    }

    .footer-section h4 {
      font-size: 1rem;
      margin-bottom: 2rem;
      color: var(--white);
      font-weight: 700;
      position: relative;
      padding-bottom: 0.5rem;
