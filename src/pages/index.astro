    .footer-bottom {
      padding: 2rem 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .footer-bottom p {
      color: rgba(245, 241, 237, 0.4);
      font-size: 0.9rem;
    }

    /* Responsive Design */
    @media (max-width: 968px) {
      .hero-content {
        padding: 1.5rem;
        background: rgba(255, 255, 255, 0.2);
      }

      .hero-title {
        font-size: 3.5rem;
      }

      .hero-description {
        font-size: 1.15rem;
      }

      .hero-overlay {
        background: linear-gradient(
          135deg,
          rgba(0, 0, 0, 0.5) 0%,
          rgba(10, 10, 30, 0.45) 50%,
          rgba(0, 0, 0, 0.5) 100%
        );
      }

      .service-item {
