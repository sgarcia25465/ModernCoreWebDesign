      }

      .hero-title {
        font-size: 2.5rem;
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.9), 0 4px 16px rgba(0, 0, 0, 0.7);
      }

      .hero-description {
        font-size: 1.05rem;
        text-shadow: 0 2px 6px rgba(0, 0, 0, 0.9), 0 4px 12px rgba(0, 0, 0, 0.7);
      }

      .hero-buttons {
        flex-direction: column;
        width: 100%;
      }

      .hero-buttons .btn {
        width: 100%;
        text-align: center;
        padding: 1.1rem 2rem;
