      }

      .hero-overlay {
        background: linear-gradient(
          135deg,
          rgba(0, 0, 0, 0.55) 0%,
          rgba(10, 10, 30, 0.5) 50%,
          rgba(0, 0, 0, 0.55) 100%
        );
      }

      .hero-video {
        width: 100vw;
        height: 100vh;
        min-width: 100%;
        min-height: 100%;
      }

      .hero-video-background {
        width: 100%;
