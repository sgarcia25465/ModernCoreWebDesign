      }

      .portfolio-project,
      .portfolio-project[data-project="2"] {
        grid-template-columns: 1fr;
        height: 540px;
        overflow: hidden;
      }

      .portfolio-project[data-project="2"] .project-image-wrapper {
        order: 1;
      }

      .portfolio-project[data-project="2"] .project-details {
