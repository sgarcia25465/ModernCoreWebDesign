  </style>

  <script>
    // Form submission handler
    const form = document.querySelector('.contact-form');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      alert('Thank you for your message! We will get back to you soon.');
      form.reset();
    });

    // Portfolio Carousel
    let currentProject = 0;
    const projects = document.querySelectorAll('.portfolio-project');
    let autoRotateInterval;

    function showProject(index) {
      // Remove active class from all projects
      projects.forEach(project => project.classList.remove('active'));

      // Add active class to current project
      projects[index].classList.add('active');
      currentProject = index;
    }

    function nextProject() {
      const next = (currentProject + 1) % projects.length;
      showProject(next);
    }

    function prevProject() {
      const prev = (currentProject - 1 + projects.length) % projects.length;
      showProject(prev);
    }

    function startAutoRotate() {
      clearInterval(autoRotateInterval);
      autoRotateInterval = setInterval(nextProject, 10000); // Change every 10 seconds
    }

    function stopAutoRotate() {
      clearInterval(autoRotateInterval);
    }

    // Arrow navigation
    const leftArrow = document.querySelector('.carousel-arrow-left');
    const rightArrow = document.querySelector('.carousel-arrow-right');

    if (leftArrow) {
      leftArrow.addEventListener('click', () => {
        stopAutoRotate();
        prevProject();
        startAutoRotate();
      });
    }

    if (rightArrow) {
      rightArrow.addEventListener('click', () => {
        stopAutoRotate();
        nextProject();
        startAutoRotate();
      });
    }

    // Pause on hover
    const carousel = document.querySelector('.portfolio-carousel');
    if (carousel) {
      carousel.addEventListener('mouseenter', stopAutoRotate);
      carousel.addEventListener('mouseleave', startAutoRotate);
    }

    // Start auto-rotation when page loads
    startAutoRotate();

    // Counter animation for stats
    function animateCounter(element, target, duration, prefix = '', suffix = '') {
      const start = 0;
      const increment = target / (duration / 16); // 60fps
      let current = start;

      const timer = setInterval(() => {
        current += increment;
        if (current >= target) {
          current = target;
          clearInterval(timer);
        }

        if (suffix === '%') {
          element.textContent = Math.floor(current) + suffix;
        } else if (prefix === '<' && suffix === 's') {
          element.textContent = prefix + current.toFixed(1) + suffix;
        } else {
          element.textContent = Math.floor(current);
        }
      }, 16);
    }

    // Observe stat boxes for counter animation
    const statsObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !entry.target.dataset.animated) {
          entry.target.dataset.animated = 'true';
          const statNumber = entry.target.querySelector('.stat-number-large');
          const text = statNumber.textContent.trim();

          if (text.includes('%')) {
            statNumber.textContent = '0%';
            animateCounter(statNumber, 100, 2000, '', '%');
          } else if (text.includes('<')) {
            statNumber.textContent = '<0.0s';
            const numberElement = statNumber;
            const start = 0;
            const target = 1;
            const duration = 2000;
            const increment = target / (duration / 16);
            let current = start;

            const timer = setInterval(() => {
              current += increment;
              if (current >= target) {
                current = target;
                clearInterval(timer);
              }
              numberElement.textContent = '<' + current.toFixed(1) + 's';
            }, 16);
          } else if (text.includes('/')) {
            statNumber.textContent = '0/0';
            let hour = 0;
            const hourTimer = setInterval(() => {
              hour += 1;
              if (hour >= 24) {
                hour = 24;
                statNumber.textContent = '24/7';
                clearInterval(hourTimer);
              } else {
                statNumber.textContent = hour + '/7';
              }
            }, 80);
          }
        }
      });
    }, { threshold: 0.5 });

    // Observe all stat boxes
    document.querySelectorAll('.stat-box').forEach(box => {
      statsObserver.observe(box);
    });

    // Fade-in animation on scroll
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -100px 0px'
    };

    const fadeObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('fade-in-visible');
        }
      });
    }, observerOptions);

    // Function to animate elements in a section
    function animateSection(sectionId) {
      const section = document.querySelector(sectionId);
      if (!section) return;

      // Get all fade elements in this section
      const elements = section.querySelectorAll('.fade-in');

      // Reset and re-trigger animation
      elements.forEach((el, index) => {
        el.classList.remove('fade-in-visible');
        const delay = index * 0.1;

        setTimeout(() => {
          el.classList.add('fade-in-visible');
        }, delay * 100);
      });
    }

    // Initialize animations when DOM is ready
    document.addEventListener('DOMContentLoaded', () => {
      // Select all text elements that should fade in (excluding hero initially)
      const fadeElements = document.querySelectorAll(
        '.section-title, .section-subtitle, .services-description, ' +
        '.service-item, ' +
        '.portfolio-carousel, .pricing-card, ' +
        '.about-story, .stat-box, .value-item, ' +
        '.contact-info h3, .contact-info p, .contact-item, .contact-form'
      );

      fadeElements.forEach((el, index) => {
        el.classList.add('fade-in');
        fadeObserver.observe(el);
      });

      // Hero section fade-in on page load
      const heroContent = document.querySelector('.hero-content');
      if (heroContent) {
        heroContent.classList.add('fade-in');
        // Trigger fade-in after a short delay
        setTimeout(() => {
          heroContent.classList.add('fade-in-visible');
        }, 500);
      }

      // Add click handlers to navigation links
      document.querySelectorAll('a[href^="#"]').forEach(link => {
        link.addEventListener('click', (e) => {
          const targetId = link.getAttribute('href');
          if (targetId && targetId !== '#') {
            // Wait for smooth scroll to almost complete, then trigger animation
            setTimeout(() => {
              animateSection(targetId);
            }, 400);
          }
        });
      });
    });
  </script>
</Layout>
